using UnityEngine;

public class Tarea: MonoBehaviour
{
    public int vida;

    void Start()
    {
        bool muerto = vida <= 0;
        bool herido = vida < 30 && vida > 0;

        if (muerto)
        {
            Debug.Log("Muerto");
        }
        else if (herido)
        {
            Debug.Log("Herido");
        }
        else
        {
            Debug.Log("Saludable");
        }
    }
}
