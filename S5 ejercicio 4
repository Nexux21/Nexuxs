using UnityEngine;

public class Tarea4 : MonoBehaviour
{
    public float velocidad;
    public Rigidbody rb; // Referencia al Rigidbody

    // Bool para cada estado
    public bool detenido;
    public bool caminando;
    public bool corriendo;
    public bool sprint;

    void Update()
    {
        

        // Resetear todos
        detenido = false;
        caminando = false;
        corriendo = false;
        sprint = false;

        // Clasificación según velocidad
        if (velocidad < 0.1f)
        {
            detenido = true;
            Debug.Log("Detenido");
        }
        else if (velocidad <= 2)
        {
            caminando = true;
            Debug.Log("Caminando");
        }
        else if (velocidad <= 5)
        {
            corriendo = true;
            Debug.Log("Corriendo");
        }
        else
        {
            sprint = true;
            Debug.Log("Sprint");
        }
    }
}
